<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pair_title"
            android:textAppearance="?attr/textAppearanceHeadlineSmall" />

        <TextView
            android:id="@+id/unauthorizedBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="#33ff5252"
            android:textColor="#b71c1c"
            android:textStyle="bold"
            android:text="@string/pair_unauthorized_banner"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/pair_intro"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <Button
            android:id="@+id/scanButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/pair_scan" />

        <Button
            android:id="@+id/rescanButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/pair_rescan"
            android:visibility="gone" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/pair_status_idle"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"
            android:background="?android:attr/listDivider" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pair_manual_summary"
            android:textAppearance="?attr/textAppearanceLabelLarge" />

        <EditText
            android:id="@+id/hostInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/pair_host_hint"
            android:inputType="text"
            android:autofillHints="off"
            android:importantForAutofill="no" />

        <EditText
            android:id="@+id/portInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/pair_port_hint"
            android:inputType="number"
            android:text="7891"
            android:autofillHints="off"
            android:importantForAutofill="no" />

        <EditText
            android:id="@+id/secretInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/pair_secret_hint"
            android:inputType="text"
            android:autofillHints="off"
            android:importantForAutofill="no" />

        <Button
            android:id="@+id/discoverButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/pair_discover" />

        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/pair_save" />

    </LinearLayout>
</ScrollView>
