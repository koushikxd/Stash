{
  "name": "pop-mac",
  "version": "0.1.0",
  "description": "pop — Mac menubar receiver for links shared from your phone.",
  "main": "dist/main/main.js",
  "scripts": {
    "clean": "rimraf dist",
    "build:ts": "tsc -p tsconfig.json",
    "build:assets": "node scripts/copy-assets.js",
    "build:icons": "node scripts/make-icons.js",
    "build": "npm run clean && npm run build:icons && npm run build:ts && npm run build:assets",
    "start": "electron .",
    "dev": "npm run build && electron .",
    "dist": "npm run build && electron-builder --mac dmg"
  },
  "author": "koushik",
  "license": "MIT",
  "dependencies": {
    "@electron/notarize": "^2.5.0",
    "bonjour-service": "^1.2.1",
    "menubar": "^9.5.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/qrcode": "^1.5.5",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}
